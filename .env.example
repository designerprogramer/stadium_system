# Copy this file to .env and fill in your actual values.
# Do not commit .env to source control.

DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.example.com
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://digital-stadium.netlify.app
CSRF_TRUSTED_ORIGINS=https://digital-stadium.netlify.app
SECURE_SSL_REDIRECT=True

# SQLite is suitable for local development. Configure PostgreSQL for production.
DB_ENGINE=django.db.backends.postgresql
DB_NAME=stadium
DB_USER=stadium
DB_PASSWORD=replace-me
DB_HOST=localhost
DB_PORT=5432

EMAIL_BACKEND=config.email_backend.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
# Set to True only if Python 3.13 strict TLS validation breaks on your SMTP CA chain.
EMAIL_TLS_RELAX_X509_STRICT=False
DEFAULT_FROM_EMAIL=no-reply@example.com

STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Frontend environment variable:
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
# VITE_API_BASE_URL=https://api.example.com/api
